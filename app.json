{
  "expo": {
    "name": "Today_I_did",
    "slug": "Today_I_did",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "todayidid",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.limheerae.TodayIdid",
      "appleTeamId": "L993PK7S6Q",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.limheerae.TodayIdid",
          "group.com.limheerae.TodayIdid"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.limheerae.Today_I_did",
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@bacons/apple-targets",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3048785-2af4-404e-9821-f4031a421207",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.limheerae.TodayIdid.widget",
                  "targetName": "TetrisWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.limheerae.TodayIdid"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f3048785-2af4-404e-9821-f4031a421207"
    }
  }
}
