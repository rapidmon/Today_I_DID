<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 외곽 어두운 테두리 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#222233" />
        </shape>
    </item>
    <!-- 그림자 (하단/우측) -->
    <item android:left="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#666677" />
        </shape>
    </item>
    <!-- 하이라이트 (상단/좌측) -->
    <item android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- 내부 그림자 -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#888899" />
        </shape>
    </item>
    <!-- 내부 하이라이트 -->
    <item android:left="2dp" android:top="2dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#DDDDEE" />
        </shape>
    </item>
    <!-- 베이스 -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#BBBBCC" />
        </shape>
    </item>
</layer-list>
