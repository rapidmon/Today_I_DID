<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF000000"
    android:padding="4dp">

    <!-- 상단 바: NEW(이미지) + TODAY I DID(이미지) + 투명도%(이미지) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header_bar"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <!-- NEW 버튼 (이미지) -->
        <ImageView
            android:id="@+id/btn_refresh"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:scaleType="center"
            android:background="@drawable/btn_neon_dark"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

        <!-- TODAY I DID 타이틀 (이미지) -->
        <ImageView
            android:id="@+id/title_image"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_weight="1"
            android:scaleType="center" />

        <!-- 투명도 % (이미지) -->
        <ImageView
            android:id="@+id/btn_opacity"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:scaleType="center"
            android:background="@drawable/btn_neon_yellow"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- 중앙: 게임판 + 사이드패널 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="2dp">

        <LinearLayout
            android:id="@+id/game_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- 게임 보드 (높이 기준으로 폭 자동 계산) -->
            <ImageView
                android:id="@+id/game_board"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:scaleType="fitStart" />

            <!-- 사이드 패널 (남은 공간 전부 차지) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="2dp">

                <!-- NEXT 박스 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/box_neon_cyan"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleType="center" />

                    <ImageView
                        android:id="@+id/next_block"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="4dp"
                        android:scaleType="center" />
                </LinearLayout>

                <!-- SCORE 박스 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/box_neon_yellow"
                    android:padding="6dp"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:id="@+id/score_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleType="center" />

                    <ImageView
                        android:id="@+id/score_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:scaleType="center" />
                </LinearLayout>

                <!-- LINES 박스 -->
                <LinearLayout
                    android:id="@+id/lines_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/box_neon_green"
                    android:padding="6dp"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:id="@+id/lines_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleType="center" />

                    <ImageView
                        android:id="@+id/lines_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:scaleType="center" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 하단 버튼 (패딩 축소) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_control_bar"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/btn_left"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="◀"
                android:textSize="18sp"
                android:textColor="#00F0FF"
                android:gravity="center"
                android:background="@drawable/btn_neon_cyan"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/btn_right"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="▶"
                android:textSize="18sp"
                android:textColor="#00F0FF"
                android:gravity="center"
                android:background="@drawable/btn_neon_cyan"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btn_down"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="▼"
                android:textSize="18sp"
                android:textColor="#00FF88"
                android:gravity="center"
                android:background="@drawable/btn_neon_green"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btn_rotate"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="↻"
                android:textSize="18sp"
                android:textColor="#FFE500"
                android:gravity="center"
                android:background="@drawable/btn_neon_yellow" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
